# HDC-24: Production environment template.
# DO NOT commit .env.prod — it is gitignored.
# Credentials should be injected by CI/CD (ECS task definition, k8s secrets, etc.).
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://PLACEHOLDER:5432/hcx?currentSchema=healthdata
SPRING_DATASOURCE_USERNAME=PLACEHOLDER
SPRING_DATASOURCE_PASSWORD=PLACEHOLDER
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY should be provided via IAM role or CI/CD injection.
# AWS_S3_ENDPOINT must NOT be set for prod — real AWS endpoint is used.
APP_HOST_PORT=8093

