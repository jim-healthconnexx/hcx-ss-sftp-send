# HDC-24: QA environment template.
# Copy to .env.qa and fill in QA values, or inject via CI/CD.
# DO NOT commit .env.qa — it is gitignored.
SPRING_PROFILES_ACTIVE=qa
SPRING_DATASOURCE_URL=jdbc:postgresql://PLACEHOLDER:5432/hcx?currentSchema=healthdata
SPRING_DATASOURCE_USERNAME=PLACEHOLDER
SPRING_DATASOURCE_PASSWORD=PLACEHOLDER
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=PLACEHOLDER
AWS_SECRET_ACCESS_KEY=PLACEHOLDER
# AWS_S3_ENDPOINT must NOT be set for QA/prod — real AWS endpoint is used.
APP_HOST_PORT=8093

